# ============================================================
# SmartFarm DakLak - Environment Configuration
# Copy this file to .env and update values for your deployment
# ============================================================

# ── MQTT ──
MQTT_URL=mqtt://localhost:1883

# ── InfluxDB ──
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
INFLUXDB_INIT_ORG=smarfarm
INFLUXDB_INIT_BUCKET=soil_data
INFLUXDB_INIT_ADMIN_TOKEN=CHANGE_ME_GENERATE_RANDOM_TOKEN

# ── PostgreSQL (ChirpStack) ──
POSTGRES_USER=chirpstack
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=chirpstack

# ── Grafana ──
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── ChirpStack ──
CHIRPSTACK_JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# ── Application ──
PORT=3002
TZ=Asia/Ho_Chi_Minh
